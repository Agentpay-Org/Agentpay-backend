# AgentPay Backend local configuration.
# Copy this file to .env for local development.
# Keep real secrets out of this committed example.

# HTTP port used by src/index.ts.
# Default: 3001
PORT=3001

# Runtime mode. Set to "test" to disable request rate limiting and structured
# request logs during automated tests.
# Default: development behavior unless explicitly set by the runtime.
NODE_ENV=development

# Comma-separated CORS allowlist. Leave empty for same-origin-only behavior.
# Example: https://dashboard.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

